// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_TGShD8vMFJ3d@ep-aged-recipe-adcvkxjs-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  profile              UserProfile?
  programs             Program[]
  challengeParticipants ChallengeParticipant[]
  cigaretteLogs        CigaretteLog[]
  cravingLogs          CravingLog[]
  dailyProgress        DailyProgress[]
  sentInvites          InviteCode[]   @relation("InviteSender")
  receivedInvites      InviteCode[]   @relation("InviteReceiver")
  achievements         UserAchievement[]
  moodCheckins         MoodCheckin[]
  patternInsights      PatternInsight[]
  cravingPredictions   CravingPrediction[]
  coachMessages        CoachMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ConsumptionType {
  SMOKING
  VAPING
}

model UserProfile {
  id                  String          @id @default(cuid())
  userId              String          @unique
  displayName         String?
  // Smoking fields (backward compatible - keep defaults)
  cigarettesPerDay    Int             @default(20)
  cigarettesPerPack   Int             @default(20)
  pricePerPack        Float           @default(4.0)
  // New: Support for both smokers and vapers
  consumptionType     ConsumptionType @default(SMOKING)
  usagePerDay         Int?            // For vapers: # of vape sessions/puffs per day
  estimatedDailyCost  Float?          // For vapers: direct daily cost estimation
  quitDate            DateTime        @default(now())
  onboardingCompleted Boolean         @default(false)
  triggers            String[]        @default([])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProgramType {
  TEN_DAY
  FOURTEEN_DAY
  THIRTY_DAY
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  PAUSED
  NEEDS_FOCUS
}

model Program {
  id            String        @id @default(cuid())
  userId        String
  type          ProgramType
  status        ProgramStatus @default(ACTIVE)
  startDate     DateTime      @default(now())
  endDate       DateTime?
  graceUsed     Int           @default(0)
  graceLimit    Int           @default(3)
  currentDay    Int           @default(1)
  isWithFriend  Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenges Challenge[]
}

model Challenge {
  id          String        @id @default(cuid())
  programId   String
  name        String
  type        ProgramType
  startDate   DateTime      @default(now())
  endDate     DateTime?
  status      ProgramStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  program      Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  graceUsed   Int      @default(0)
  joinedAt    DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

enum TriggerType {
  STRESS
  COFFEE
  ALCOHOL
  SOCIAL
  BOREDOM
  AFTER_MEAL
  DRIVING
  OTHER
}

model CigaretteLog {
  id        String       @id @default(cuid())
  userId    String
  trigger   TriggerType?
  note      String?
  isGrace   Boolean      @default(false)
  loggedAt  DateTime     @default(now())
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CravingLog {
  id             String       @id @default(cuid())
  userId         String
  trigger        TriggerType?
  note           String?
  resolved       Boolean      @default(false)
  resolutionType String?
  duration       Int?
  loggedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyProgress {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @db.Date
  cigarettesSmoked Int      @default(0)
  cravingsLogged   Int      @default(0)
  cravingsResolved Int      @default(0)
  taskCompleted    Boolean  @default(false)
  reflectionNote   String?
  moodScore        Int?
  dailyMood        MoodType?
  supportActionsUsed String[] @default([])
  coachInteractions Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  senderId    String
  receiverId  String?
  challengeId String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  sender   User  @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User? @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model HealthMilestoneProgress {
  id           String   @id @default(cuid())
  userId       String
  milestoneKey String
  achievedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([userId, milestoneKey])
}

// Smart Features - Behavioral Analysis & AI Coaching

enum MoodType {
  EXCELLENT
  GOOD
  DIFFICULT
  STRONG_CRAVING
}

model MoodCheckin {
  id        String   @id @default(cuid())
  userId    String
  mood      MoodType
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PatternInsight {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "time_of_day", "trigger_frequency", "weekly_pattern", etc.
  title       String   // "Najviše želja javlja se između 8:00 i 10:00"
  description String?
  data        String   // JSON with pattern data
  confidence  Float    @default(0.0) // 0.0 to 1.0
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, isActive])
}

model CravingPrediction {
  id              String   @id @default(cuid())
  userId          String
  predictedTime   DateTime // When craving is predicted
  riskScore       Float    // 0.0 to 1.0
  basedOnTriggers String[] // ["COFFEE", "STRESS"]
  basedOnTimes    String[] // ["09:00", "14:30"]
  suggestion      String?  // "Probaj sada uzeti čašu vode..."
  wasAccurate     Boolean? // Track if prediction was correct
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, predictedTime])
}

enum CoachMessageContext {
  DASHBOARD
  CRAVING_MODAL
  END_OF_DAY
  MILESTONE
  DIFFICULT_MOMENT
  STREAK
  GRACE_USED
}

model CoachMessage {
  id          String              @id @default(cuid())
  userId      String
  context     CoachMessageContext
  message     String
  isDisplayed Boolean             @default(false)
  displayedAt DateTime?
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDisplayed, context])
}
